{
  "name": "@getpopapi/pop-mcp",
  "mcpName": "io.github.popapidev/pop-mcp",
  "version": "1.1.0",
  "description": "MCP server for POP Cloud API — Italian e-invoicing (SdI/FatturaPA), Peppol, PDF invoice generation, and account onboarding",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pop-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pop-api",
    "e-invoice",
    "fatturapa",
    "sdi",
    "peppol",
    "italian-invoicing",
    "onboarding"
  ],
  "author": "getpopapi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getpopapi/pop-mcp.git"
  },
  "homepage": "https://popapi.io",
  "publishConfig": {
    "access": "public"
  }
}
